FROM rust:1-bookworm AS builder
WORKDIR /app
COPY . .
ARG TRACTOR_BEAM_GIT_HASH=""
RUN cargo build --locked --release -p tractor-beam-relay

FROM debian:bookworm-slim
WORKDIR /app
COPY --from=builder /app/target/release/tractor-beam-relay /usr/local/bin/tractor-beam-relay
COPY deploy/relay.toml /etc/tractor-beam/relay.toml
EXPOSE 25910/udp
EXPOSE 25910/tcp
ENTRYPOINT ["tractor-beam-relay"]
CMD ["--config", "/etc/tractor-beam/relay.toml"]
